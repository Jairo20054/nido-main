# NIDO frontend environment
# Copy to frontend/.env only if you want frontend-specific overrides.
# Root .env is the recommended default for local development.
# These values are public because Vite exposes VITE_* variables to the browser.

VITE_API_URL="/api"
VITE_SITE_URL="http://localhost:5173"

VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_ANON_KEY="replace-with-supabase-anon-or-publishable-key"
# Alternative for newer Supabase projects:
# VITE_SUPABASE_PUBLISHABLE_KEY="replace-with-supabase-publishable-key"

VITE_SUPABASE_PROPERTY_MEDIA_BUCKET="property-media-public"
# Public MapTiler key used by the browser to load map styles, tiles and static map images.
VITE_MAPTILER_KEY=""
VITE_SUPABASE_REDIRECT_URL="http://localhost:5173/reset-password"
VITE_SUPABASE_EMAIL_CONFIRMATION_URL="http://localhost:5173/email-confirmed"
VITE_SUPABASE_OAUTH_REDIRECT_URL="http://localhost:5173/auth/callback"
# Public HTTPS logo URL for Supabase Auth email templates and brand docs.
# Use the deployed frontend domain; never use a local Windows path in email HTML.
VITE_NIDO_PUBLIC_LOGO_URL="https://your-production-domain.com/brand/nido-logo.png"

# Never add VITE_SUPABASE_SERVICE_ROLE_KEY, VITE_SUPABASE_SECRET_KEY,
# VITE_JWT_SECRET, VITE_DATABASE_URL, GOOGLE_CLIENT_SECRET or similar private values here.
