# NIDO backend environment
# Copy to backend/.env only if you want backend-specific overrides.
# Root .env is the recommended default for local development.

NODE_ENV=development
PORT=5000

DATABASE_URL="postgresql://postgres:<password>@127.0.0.1:54322/postgres?schema=public"
DIRECT_URL="postgresql://postgres:<password>@127.0.0.1:54322/postgres?schema=public"

# Required in staging/production. Keep server-side only.
JWT_SECRET="replace-with-a-long-random-secret"

# Comma-separated frontend origins allowed by CORS.
CLIENT_URLS="http://localhost:5173,http://127.0.0.1:5173"

SUPABASE_URL="https://<project-ref>.supabase.co"
SUPABASE_ANON_KEY="replace-with-supabase-anon-or-publishable-key"
# SUPABASE_PUBLISHABLE_KEY="replace-with-supabase-publishable-key"

# Server-only. Never expose this as VITE_* and never use it in frontend code.
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-or-secret-key"
SUPABASE_PROPERTY_MEDIA_BUCKET="property-media-public"

DEEPSEK_API_KEY=""
DEEPSEK_API_BASE="https://api.deepsek.ai"
