# Backend / Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/nido_media"
DIRECT_URL="postgresql://postgres:postgres@localhost:5433/nido_media"
PORT=5000
CLIENT_URL="http://localhost:5173"
CLIENT_URLS="http://localhost:5173"

# Supabase server-side config. Keep service/secret keys out of frontend code.
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_ANON_KEY="your-anon-key"
# Server-only. Never expose this through VITE_* variables or frontend code.
SUPABASE_SECRET_KEY="your-secret-key"
SUPABASE_SERVICE_KEY="your-service-role-or-secret-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_PROPERTY_MEDIA_BUCKET="property-media-public"

# Frontend public config. Vite only exposes variables prefixed with VITE_.
VITE_API_BASE_URL="/api"
VITE_SITE_URL="http://localhost:5173"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
VITE_SUPABASE_ANON_KEY="your-anon-key"
VITE_SUPABASE_PROPERTY_MEDIA_BUCKET="property-media-public"
VITE_SUPABASE_REDIRECT_URL="http://localhost:5173/reset-password"
VITE_SUPABASE_EMAIL_CONFIRMATION_URL="http://localhost:5173/login"
VITE_ADMIN_LOGIN_ALIAS="admin"
VITE_ADMIN_LOGIN_EMAIL="admin@nido.local"
VITE_SUPER_ADMIN_LOGIN_ALIAS="superadmin"
VITE_SUPER_ADMIN_LOGIN_EMAIL="admin@nido.local"

ADMIN_LOGIN_ALIAS="admin"
ADMIN_LOGIN_EMAIL="admin@nido.local"
ADMIN_LOGIN_PASSWORD="change-me-before-running-bootstrap"
SUPER_ADMIN_LOGIN_ALIAS="superadmin"
SUPER_ADMIN_LOGIN_EMAIL="admin@nido.local"
SUPER_ADMIN_LOGIN_PASSWORD="change-me-before-running-bootstrap"
