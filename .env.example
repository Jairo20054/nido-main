# Option B keeps auth/profile on Supabase Admin SDK. Leave Prisma empty unless
# you are intentionally wiring remaining non-auth controllers to hosted Postgres.
DATABASE_URL=""
DIRECT_URL=""
# Supabase Postgres placeholders for the remaining Prisma-backed modules:
# DATABASE_URL="postgresql://postgres.your-project-ref:your-db-password@aws-0-your-region.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.your-project-ref:your-db-password@aws-0-your-region.pooler.supabase.com:5432/postgres"
PORT=5000
CLIENT_URL="http://localhost:5173"
CLIENT_URLS="http://localhost:5173"
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
SUPABASE_ANON_KEY="your-anon-key"
# Server-only. Never expose this through VITE_* variables or frontend code.
SUPABASE_SECRET_KEY="your-secret-key"
SUPABASE_SERVICE_KEY="your-service-role-or-secret-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_PROPERTY_MEDIA_BUCKET="property-media-public"
VITE_API_BASE_URL="/api"
VITE_SITE_URL="http://localhost:5173"
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="your-publishable-key"
VITE_SUPABASE_ANON_KEY="your-anon-key"
VITE_SUPABASE_PROPERTY_MEDIA_BUCKET="property-media-public"
VITE_SUPABASE_REDIRECT_URL="http://localhost:5173/reset-password"
VITE_SUPABASE_EMAIL_CONFIRMATION_URL="http://localhost:5173/login"
VITE_ADMIN_LOGIN_ALIAS="admin"
VITE_ADMIN_LOGIN_EMAIL="admin@nido.local"
VITE_SUPER_ADMIN_LOGIN_ALIAS="superadmin"
VITE_SUPER_ADMIN_LOGIN_EMAIL="admin@nido.local"

ADMIN_LOGIN_ALIAS="admin"
ADMIN_LOGIN_EMAIL="admin@nido.local"
ADMIN_LOGIN_PASSWORD="change-me-before-running-bootstrap"
SUPER_ADMIN_LOGIN_ALIAS="superadmin"
SUPER_ADMIN_LOGIN_EMAIL="admin@nido.local"
SUPER_ADMIN_LOGIN_PASSWORD="change-me-before-running-bootstrap"
