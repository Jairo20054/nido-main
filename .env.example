# NIDO local environment (combined backend + frontend)
# Copy this file to .env and fill real values from your password manager.
# Never commit .env. Values below are placeholders only.

NODE_ENV=development
PORT=5000

# Prisma / PostgreSQL
# Local Supabase CLI usually uses port 54322. Docker/local Postgres may use another port.
DATABASE_URL="postgresql://postgres:<password>@127.0.0.1:54322/postgres?schema=public"
DIRECT_URL="postgresql://postgres:<password>@127.0.0.1:54322/postgres?schema=public"

# Backend security
# Required in staging/production. Use a long random value.
JWT_SECRET="replace-with-a-long-random-secret"

# CORS
CLIENT_URLS="http://localhost:5173,http://127.0.0.1:5173"

# Supabase backend
SUPABASE_URL="https://<project-ref>.supabase.co"
# Use either SUPABASE_ANON_KEY or SUPABASE_PUBLISHABLE_KEY for public/browser-safe flows.
SUPABASE_ANON_KEY="replace-with-supabase-anon-or-publishable-key"
# SUPABASE_PUBLISHABLE_KEY="replace-with-supabase-publishable-key"
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-or-secret-key"
SUPABASE_PROPERTY_MEDIA_BUCKET="property-media-public"

# Optional integrations
DEEPSEK_API_KEY=""
DEEPSEK_API_BASE="https://api.deepsek.ai"

# Frontend public variables. Only VITE_* variables are bundled into the browser.
VITE_API_URL="/api"
VITE_SITE_URL="http://localhost:5173"
VITE_SUPABASE_URL="https://<project-ref>.supabase.co"
VITE_SUPABASE_ANON_KEY="replace-with-supabase-anon-or-publishable-key"
# VITE_SUPABASE_PUBLISHABLE_KEY="replace-with-supabase-publishable-key"
VITE_SUPABASE_PROPERTY_MEDIA_BUCKET="property-media-public"
VITE_SUPABASE_REDIRECT_URL="http://localhost:5173/reset-password"
VITE_SUPABASE_EMAIL_CONFIRMATION_URL="http://localhost:5173/email-confirmed"
VITE_SUPABASE_OAUTH_REDIRECT_URL="http://localhost:5173/auth/callback"

# Google OAuth is configured in Supabase Auth and Google Cloud, not as frontend env vars.
# Do not add GOOGLE_CLIENT_SECRET or any Google secret to VITE_* variables.

# Optional local admin bootstrap. Do not reuse these placeholders.
ADMIN_LOGIN_ALIAS="admin"
ADMIN_LOGIN_EMAIL="admin@nido.local"
ADMIN_LOGIN_PASSWORD="replace-with-local-admin-password"
SUPER_ADMIN_LOGIN_ALIAS="superadmin"
SUPER_ADMIN_LOGIN_EMAIL="admin@nido.local"
SUPER_ADMIN_LOGIN_PASSWORD="replace-with-local-super-admin-password"
