{
  "name": "nido",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma minimalista para arrendamiento de propiedades",
  "scripts": {
    "postinstall": "node scripts/prisma-generate-safe.js",
    "prestart": "npm run env:check && node scripts/prestart.js",
    "dev": "node scripts/dev.js",
    "predev": "npm run env:check && node scripts/prestart.js",
    "dev:client": "vite --config frontend/vite.config.js",
    "dev:frontend": "vite --config frontend/vite.config.js",
    "dev:backend": "nodemon backend/src/server.js",
    "dev:server": "nodemon backend/src/server.js",
    "build": "vite build --config frontend/vite.config.js",
    "preview": "vite preview --config frontend/vite.config.js",
    "start:backend": "node backend/src/server.js",
    "start": "node backend/src/server.js",
    "env:check": "node scripts/env-check.js",
    "env:check:backend": "node scripts/env-check.js --scope=backend",
    "env:check:frontend": "node scripts/env-check.js --scope=frontend",
    "lint": "npm run env:check",
    "typecheck": "npm run env:check",
    "test": "node --test",
    "auth:bootstrap-admin": "node scripts/bootstrap-admin.js",
    "supabase:create-admin": "node backend/scripts/create-supabase-admin.js",
    "prisma:doctor": "node scripts/prisma-generate-safe.js --check",
    "prisma:generate": "node scripts/prisma-generate-safe.js",
    "prisma:migrate": "prisma migrate dev --schema backend/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema backend/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema backend/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema backend/prisma/schema.prisma",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/client": "^6.17.0",
    "@supabase/supabase-js": "^2.104.0",
    "bcryptjs": "^2.4.3",
    "clsx": "^2.1.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "eventsource-parser": "^3.0.8",
    "express": "^4.21.2",
    "joi": "^18.0.1",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.8.0",
    "node-fetch": "^3.3.2",
    "openai": "^6.35.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.9.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "nodemon": "^3.1.10",
    "prisma": "^6.17.0",
    "vite": "^8.0.10"
  }
}
